generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Requirement {
  requirementId Int      @id @default(autoincrement()) @map("requirement_id")
  systemId      String   @unique @map("system_id")
  name          String   @map("name")
  content       String?  @map("content")       // 요구사항 내용 (원문 HTML)
  description   String?  @map("description")   // 요구사항 분석 내용 (HTML)
  priority      String?  @map("priority")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  screens Screen[]

  @@map("tb_requirement")
}

model Screen {
  screenId      Int      @id @default(autoincrement()) @map("screen_id")
  systemId      String   @unique @map("system_id")
  displayCode   String?  @map("display_code")
  name          String   @map("name")
  screenType    String?  @map("screen_type")
  requirementId Int      @map("requirement_id")
  spec          String?  @map("spec")             // 화면 설명 (마크다운)
  layoutData    String?  @map("layout_data")      // 레이아웃 JSON 문자열
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  requirement Requirement @relation(fields: [requirementId], references: [requirementId])
  functions   Function[]

  @@map("tb_screen")
}

model Function {
  functionId  Int      @id @default(autoincrement()) @map("function_id")
  systemId    String   @unique @map("system_id")
  displayCode String?  @map("display_code")
  name        String   @map("name")
  screenId    Int      @map("screen_id")

  spec        String?  @map("spec")
  dataFlow    String?  @map("data_flow")
  changeReason String? @map("change_reason")

  status      String   @default("DRAFT") @map("status")  // DRAFT | REVIEW_REQ | AI_REVIEWING | REVIEW_DONE | DESIGN_REQ | DESIGN_DONE | CONFIRM_Y | IMPL_REQ | AI_IMPLEMENTING | IMPL_DONE
  priority    String   @default("MEDIUM") @map("priority")

  aiSummary           String? @map("ai_summary")
  aiReviewResult      String? @map("ai_review_result")
  aiConflictFunctions String? @map("ai_conflict_functions")
  aiImpactAnalysis    String? @map("ai_impact_analysis")
  aiDesignContent     String? @map("ai_design_content") // AI가 작성한 상세 설계 내용 (마크다운)
  aiImplFeedback      String? @map("ai_impl_feedback")
  aiImplIssues        String? @map("ai_impl_issues")
  gitlabPrUrl         String? @map("gitlab_pr_url")
  relatedFiles        String? @map("related_files")
  refContent          String? @map("ref_content")   // 참고 프로그램 내용 (마크다운)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  screen Screen @relation(fields: [screenId], references: [screenId])

  @@index([status])
  @@index([screenId])
  @@map("tb_function")
}

model AiTask {
  aiTaskId     Int       @id @default(autoincrement()) @map("ai_task_id")
  systemId     String    @unique @map("system_id")
  refTableName String    @map("ref_table_name")  // "tb_function" | "tb_standard_guide" | ...
  refPkId      Int       @map("ref_pk_id")        // 대상 테이블의 PK
  taskType     String    @map("task_type")        // DESIGN | REVIEW | IMPLEMENT | IMPACT | REPROCESS | INSPECT
  taskStatus   String    @default("NONE") @map("task_status") // NONE | RUNNING | SUCCESS | AUTO_FIXED | NEEDS_CHECK | WARNING | FAILED

  spec        String?   @map("spec")             // AI 호출 시점 내용 스냅샷
  comment     String?   @map("comment")          // GS 추가 요청 (재처리용, NULL이면 최초 요청)
  feedback    String?   @map("feedback")         // AI 결과 (마크다운 통째로)
  resultFiles String?   @map("result_files")     // AI가 수정한 파일 목록 (줄바꿈 구분)

  requestedAt DateTime  @default(now()) @map("requested_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([taskStatus])
  @@index([refTableName, refPkId])
  @@map("tb_ai_task")
}

model Sequence {
  sequenceId Int    @id @default(autoincrement()) @map("sequence_id")
  prefix     String @unique @map("prefix")
  lastValue  Int    @default(0) @map("last_value")

  @@map("tb_sequence")
}

model Attachment {
  attachmentId Int      @id @default(autoincrement()) @map("attachment_id")
  refTableName String   @map("ref_table_name")
  refPkId      Int      @map("ref_pk_id")
  logicalName  String   @map("logical_name")
  physicalName String   @map("physical_name")
  filePath     String   @map("file_path")
  fileSize     Int      @map("file_size")
  fileExt      String?  @map("file_ext")
  description  String?  @map("description")
  delYn        String   @default("N") @map("del_yn")
  createdBy    String   @default("GS") @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refTableName, refPkId])
  @@map("tb_attachment")
}

model StandardGuide {
  guideId   Int      @id @default(autoincrement()) @map("guide_id")
  systemId  String   @unique @db.VarChar(10) @map("system_id")
  category  String   @map("category")  // UI | DATA | AUTH | API | COMMON | SECURITY | FILE | ERROR | BATCH | REPORT
  title     String   @map("title")
  content              String?   @map("content")                // 마크다운 가이드 내용
  relatedFiles         String?   @map("related_files")           // 관련 파일 목록 (줄바꿈 구분)
  isActive             String    @default("Y") @map("is_active") // Y | N
  status               String    @default("") @map("status")     // REVIEW_REQ | REVIEW_DONE
  aiFeedbackContent    String?   @map("ai_feedback_content")     // AI 피드백 내용 (마크다운)
  aiFeedbackAt         DateTime? @map("ai_feedback_at")          // AI 피드백 수정 시각
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@map("tb_standard_guide")
}
