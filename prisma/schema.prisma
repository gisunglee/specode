generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 기획 드래프트. AI와 협업하여 IA/Process/Mockup 결과물을 도출하는 샌드박스 공간.
model PlanningDraft {
  planSn        Int      @id @default(autoincrement()) @map("plan_sn")
  planNm        String   @map("plan_nm")
  planType      String?  @map("plan_type")           // IA / PROCESS / MOCKUP
  manualInfo    String?  @map("manual_info")         // 사용자 상세 아이디어 (AI 1순위)
  comment       String?                              // AI 지시사항 프롬프트
  resultContent String?  @map("result_content")      // AI 생성 결과 (MD/HTML/Mermaid)
  resultType    String?  @map("result_type")         // MD / HTML / MERMAID
  groupUuid     String   @map("group_uuid")          // 연속 화면 세트 묶음 ID
  sortOrd       Int      @default(1) @map("sort_ord") // 그룹 내 순서
  isPicked      Boolean  @default(false) @map("is_picked")  // 확정 마킹 (화면설계 승격 후보)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  reqMaps  PlanningReqMap[]

  @@index([groupUuid])
  @@map("tb_planning_draft")
}

/// 기획-요구사항 매핑. 하나의 기획이 참조하는 여러 요구사항을 연결.
model PlanningReqMap {
  mapSn         Int      @id @default(autoincrement()) @map("map_sn")
  planSn        Int      @map("plan_sn")
  requirementId Int      @map("requirement_id")
  createdAt     DateTime @default(now()) @map("created_at")

  plan        PlanningDraft @relation(fields: [planSn], references: [planSn], onDelete: Cascade)
  requirement Requirement   @relation(fields: [requirementId], references: [requirementId])

  @@unique([planSn, requirementId])
  @@map("tb_planning_req_map")
}

/// RFP 원문 대항목. 여러 요구사항으로 분할되는 분석 단위.
model Task {
  taskId      Int      @id @default(autoincrement()) @map("task_id")
  systemId    String   @unique @map("system_id")  // T-00001
  taskNo      String?  @map("task_no")             // 과업 번호 (사용자 정의)
  name        String                               // 과업명
  category    String?                              // 분류 (기능 요구사항 등)
  definition  String?                              // 요약 정의
  outputInfo  String?  @map("output_info")         // 산출정보
  rfpPage     Int?     @map("rfp_page")            // RFP 페이지 번호
  content     String?                              // RFP 세부내용 원문 전체
  createdAt   DateTime @default(now()) @map("created_at")

  requirements Requirement[]

  @@map("tb_task")
}

model Requirement {
  requirementId   Int      @id @default(autoincrement()) @map("requirement_id")
  systemId        String   @unique @map("system_id")
  name            String   @map("name")
  originalContent String?  @map("original_content")  // 요구사항 원문 보존용 (계약 근거)
  currentContent  String?  @map("current_content")   // 협의/변경이 반영된 최종본
  detailSpec      String?  @map("detail_spec")        // 요구사항 명세서
  priority        String?  @map("priority")
  taskId          Int?     @map("task_id")             // 소속 과업 (nullable)
  source          String   @default("RFP") @map("source")  // 출처 (RFP, 내부, 추가 등)
  discussionMd    String?  @map("discussion_md")       // AI 학습용 상세 협의 내용
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  task        Task?            @relation(fields: [taskId], references: [taskId])
  screens     Screen[]
  userStories UserStory[]
  planReqMaps PlanningReqMap[]

  @@index([taskId])
  @@map("tb_requirement")
}

model Screen {
  screenId      Int      @id @default(autoincrement()) @map("screen_id")
  systemId      String   @unique @map("system_id")
  displayCode   String?  @map("display_code")
  name          String   @map("name")
  screenType    String?  @map("screen_type")
  requirementId Int      @map("requirement_id")
  spec          String?  @map("spec")             // 화면 설명 (마크다운)
  layoutData    String?  @map("layout_data")      // 레이아웃 JSON 문자열
  categoryL     String?  @map("category_l")       // 대분류 (대메뉴)
  categoryM     String?  @map("category_m")       // 중분류 (중메뉴)
  categoryS     String?  @map("category_s")       // 소분류 (3depth 메뉴)
  menuOrder     Int?     @map("menu_order")        // 메뉴 정렬 순서
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  requirement Requirement      @relation(fields: [requirementId], references: [requirementId])
  areas       Area[]
  storyMaps   ScreenStoryMap[]

  @@map("tb_screen")
}

model Area {
  areaId         Int      @id @default(autoincrement()) @map("area_id")
  areaCode       String   @unique @map("area_code")       // AR-00001
  screenId       Int?     @map("screen_id")
  name           String   @map("name")
  sortOrder      Int      @default(1) @map("sort_order")
  areaType       String   @map("area_type")               // GRID|FORM|INFO_CARD|TAB|FULL_SCREEN
  spec           String?  @map("spec")
  layoutData     String?  @map("layout_data")              // 레이아웃 JSON 문자열
  designData     String?  @map("design_data")              // Excalidraw 설계 JSON 데이터
  status         String   @default("NONE") @map("status") // NONE|DESIGN_REQ|DESIGN_DONE|CONFIRM_Y
  reqComment     String?  @map("req_comment")
  aiFeedback     String?  @map("ai_feedback")
  useYn          String   @default("Y") @map("use_yn")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedBy      String?  @map("updated_by")
  updatedAt      DateTime @updatedAt @map("updated_at")

  screen    Screen?    @relation(fields: [screenId], references: [screenId])
  functions Function[]

  @@index([screenId])
  @@index([status])
  @@map("tb_area")
}

model Function {
  functionId  Int      @id @default(autoincrement()) @map("function_id")
  systemId    String   @unique @map("system_id")
  displayCode String?  @map("display_code")
  name        String   @map("name")
  areaId      Int?     @map("area_id")
  sortOrder   Int?     @default(0) @map("sort_order")  // 기능 정렬 순서

  spec         String?  @map("spec")
  changeReason String?  @map("change_reason")

  status   String @default("DRAFT") @map("status")  // DRAFT | REVIEW_REQ | AI_REVIEWING | REVIEW_DONE | DESIGN_REQ | DESIGN_DONE | CONFIRM_Y | IMPL_REQ | AI_IMPLEMENTING | IMPL_DONE
  priority String @default("MEDIUM") @map("priority")

  aiInspFeedback  String? @map("ai_insp_feedback")
  aiDesignContent String? @map("ai_design_content") // AI가 작성한 상세 설계 내용 (마크다운)
  aiImplFeedback  String? @map("ai_impl_feedback")
  gitlabPrUrl     String? @map("gitlab_pr_url")
  refContent      String? @map("ref_content")   // 참고 프로그램 내용 (마크다운)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  area Area? @relation(fields: [areaId], references: [areaId])

  @@index([status])
  @@index([areaId])
  @@map("tb_function")
}

model AiTask {
  aiTaskId     Int       @id @default(autoincrement()) @map("ai_task_id")
  systemId     String    @unique @map("system_id")
  refTableName String    @map("ref_table_name")  // "tb_function" | "tb_standard_guide" | "tb_area"
  refPkId      Int       @map("ref_pk_id")        // 대상 테이블의 PK
  taskType     String    @map("task_type")        // DESIGN | REVIEW | IMPLEMENT | IMPACT | REPROCESS | INSPECT | PRD_EXPORT
  taskStatus   String    @default("NONE") @map("task_status") // NONE | RUNNING | SUCCESS | AUTO_FIXED | NEEDS_CHECK | WARNING | FAILED

  spec            String?   @map("spec")              // AI 호출 시점 spec 필드 스냅샷 (하위 호환)
  contextSnapshot String?   @map("context_snapshot")  // JSON: {spec, aiDesignContent, refContent} 전체 스냅샷
  changeNote      String?   @map("change_note")        // 이전 구현 대비 변경사항 메모 (사용자 작성 or 자동 생성)
  comment     String?   @map("comment")          // GS 추가 요청 (재처리용, NULL이면 최초 요청)
  feedback    String?   @map("feedback")         // AI 결과 (마크다운 통째로)
  resultFiles String?   @map("result_files")     // AI가 수정한 파일 목록 (줄바꿈 구분)

  requestedAt DateTime  @default(now()) @map("requested_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([taskStatus])
  @@index([refTableName, refPkId])
  @@map("tb_ai_task")
}

model Sequence {
  sequenceId Int    @id @default(autoincrement()) @map("sequence_id")
  prefix     String @unique @map("prefix")
  lastValue  Int    @default(0) @map("last_value")

  @@map("tb_sequence")
}

model Attachment {
  attachmentId Int      @id @default(autoincrement()) @map("attachment_id")
  refTableName String   @map("ref_table_name")
  refPkId      Int      @map("ref_pk_id")
  logicalName  String   @map("logical_name")
  physicalName String   @map("physical_name")
  filePath     String   @map("file_path")
  fileSize     Int      @map("file_size")
  fileExt      String?  @map("file_ext")
  description  String?  @map("description")
  delYn        String   @default("N") @map("del_yn")
  createdBy    String   @default("GS") @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refTableName, refPkId])
  @@map("tb_attachment")
}

model ContentVersion {
  versionId    BigInt   @id @default(autoincrement()) @map("version_id")
  refTableName String   @map("ref_table_name")
  refPkId      Int      @map("ref_pk_id")
  fieldName    String   @map("field_name")
  aiTaskId     Int?     @map("ai_task_id")
  content      String   @map("content")
  changedBy    String   @default("user") @map("changed_by")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([refTableName, refPkId, fieldName, createdAt(sort: Desc)], name: "idx_content_version_lookup")
  @@index([aiTaskId], name: "idx_content_version_ai_task")
  @@map("tb_content_version")
}

model DbSchema {
  schemaId       Int      @id @default(autoincrement()) @map("schema_id")
  tableName      String   @unique @db.VarChar(100) @map("table_name")
  entityName     String?  @db.VarChar(100) @map("entity_name")
  tableComment   String?  @db.VarChar(200) @map("table_comment")
  ddlScript      String   @map("ddl_script")
  relationsJson  String?  @map("relations_json")
  tableGroup     String?  @db.VarChar(50)  @map("table_group")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tableGroup])
  @@map("tb_db_schema")
}

model UserStory {
  userStoryId        Int      @id @default(autoincrement()) @map("user_story_id")
  requirementId      Int      @map("requirement_id")
  systemId           String   @unique @map("system_id")
  name               String
  persona            String?
  scenario           String?
  acceptanceCriteria Json?    @map("acceptance_criteria")  // [{text: string}][]
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  requirement Requirement      @relation(fields: [requirementId], references: [requirementId])
  screenMaps  ScreenStoryMap[]

  @@index([requirementId])
  @@map("tb_user_story")
}

model ScreenStoryMap {
  mapSn       Int      @id @default(autoincrement()) @map("map_sn")
  screenId    Int      @map("screen_id")
  userStoryId Int      @map("user_story_id")
  isMainStory Boolean  @default(false) @map("is_main_story")
  createdAt   DateTime @default(now()) @map("created_at")

  screen    Screen    @relation(fields: [screenId], references: [screenId], onDelete: Cascade)
  userStory UserStory @relation(fields: [userStoryId], references: [userStoryId], onDelete: Cascade)

  @@unique([screenId, userStoryId])
  @@index([screenId])
  @@map("tb_screen_story_map")
}

model StandardGuide {
  guideId   Int      @id @default(autoincrement()) @map("guide_id")
  systemId  String   @unique @db.VarChar(10) @map("system_id")
  category  String   @map("category")  // UI | DATA | AUTH | API | COMMON | SECURITY | FILE | ERROR | BATCH | REPORT
  title     String   @map("title")
  content              String?   @map("content")                // 마크다운 가이드 내용
  relatedFiles         String?   @map("related_files")           // 관련 파일 목록 (줄바꿈 구분)
  isActive             String    @default("Y") @map("is_active") // Y | N
  status               String    @default("") @map("status")     // REVIEW_REQ | REVIEW_DONE
  aiFeedbackContent    String?   @map("ai_feedback_content")     // AI 피드백 내용 (마크다운)
  aiFeedbackAt         DateTime? @map("ai_feedback_at")          // AI 피드백 수정 시각
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@map("tb_standard_guide")
}
